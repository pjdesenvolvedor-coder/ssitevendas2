rules_version = '2';

/**
 * PJ CONTAS - Regras de Desenvolvimento
 * 
 * ATENÇÃO: Estas regras estão configuradas como ABERTAS conforme solicitação do usuário.
 * Qualquer pessoa com o ID do projeto pode ler e escrever no banco de dados.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}